#!/bin/sh /etc/rc.common

# A separate procd service is deliberate: rpcd rollback reloads cake-autorate,
# and the transaction supervisor must survive that reload to verify the exact
# restored snapshots, remove the token and publish a terminal receipt.

START=98
STOP=3
USE_PROCD=1

APPLY_GUARD="${CAKE_AUTORATE_APPLY_GUARD:-/usr/libexec/cake-autorate-rs/apply-guard}"

start_service() {
	local output token short

	[ -x "$APPLY_GUARD" ] || {
		logger -t cake-autorate-apply-guard "apply-guard helper is unavailable"
		return 1
	}
	output="$($APPLY_GUARD verify-init 2>&1)" || {
		logger -t cake-autorate-apply-guard "refusing to supervise an unverified transaction: $output"
		return 1
	}
	case "$output" in *'"state":"verified"'*) ;; *)
		logger -t cake-autorate-apply-guard "apply-guard returned no verified transaction"
		return 1
		;;
	esac
	token="$(printf '%s\n' "$output" |
		sed -n 's/.*"token":"\([0-9a-f][0-9a-f]*\)".*/\1/p')"
	case "$token" in
		????????????????????????????????????????????????????????????????)
			case "$token" in *[!0-9a-f]*) return 1 ;; esac
			;;
		*) return 1 ;;
	esac
	short="$(printf '%s' "$token" | cut -c1-12)"
	procd_open_instance "transaction_$short"
	procd_set_param command "$APPLY_GUARD" supervise "$token"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
